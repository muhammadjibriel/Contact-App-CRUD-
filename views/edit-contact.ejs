<form class="add-contact" method="post" action="/contact?_method=PUT">
  <input type="hidden" name="_id" value="<%= contact._id %>">
  <input type="hidden" name="namaLama" value="<%= contact.namaLama || contact.nama  %>">
  <h1>Ubah Data Contact</h1>
  <% if (typeof errors != 'undefined') { %>
   <div role="alert" class="alert">
    <ul>
      <% errors.forEach(error => { %>
        <li><%= error.msg %> </li>
      <% }) %>
    </ul>
   </div>
  <% } %>
  <label for="nama">Nama</label>
  <input type="text" placeholder="john albert" value="<%= contact.nama %>"  id="nama" name="nama" required />
  <label for="nohp">Nomor HP</label>
  <input type="tel" placeholder="08xxxxxxx"value="<%= contact.nohp %>" id="nohp" name="nohp" required />
  <label for="email">Email</label>
  <input
  value="<%= contact.email %>"
    type="email"
    placeholder="Test@gmail.com"
    id="email"
    name="email"
    required
  />
  <input type="submit" value="Ubah Contact!" id="submit" />
</form>


  